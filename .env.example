# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real tokens.

# ── Required for real Apify runs ────────────────────────────────────────────
# Get your token from: https://console.apify.com/account/integrations
APIFY_TOKEN=

# ── Optional overrides ──────────────────────────────────────────────────────
# Default is clockworks~tiktok-scraper (matches the upstream spec)
APIFY_ACTOR_ID=clockworks~tiktok-scraper
