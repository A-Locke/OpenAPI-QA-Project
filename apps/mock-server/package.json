{
  "name": "@specguard/mock-server",
  "version": "1.0.0",
  "private": true,
  "description": "Deterministic Fastify mock server for contract testing the wrapper API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@specguard/shared-types": "workspace:*",
    "fastify": "^4.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.14",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
